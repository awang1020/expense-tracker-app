{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "rewrite": "/.auth/login/github",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/logout",
      "rewrite": "/.auth/logout",
      "allowedRoles": ["anonymous", "authenticated"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "/*.{svg,ico,png,jpg,jpeg,gif,webp,webmanifest,js,css,map,txt}"
    ]
  }
}

